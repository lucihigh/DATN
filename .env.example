# Application
NODE_ENV=development
APP_BASE_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-this-db-password
POSTGRES_DB=ewallet
DATABASE_URL=postgresql://postgres:change-this-db-password@localhost:5432/ewallet

# Authentication and encryption
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d
ENCRYPTION_KEY=replace-with-a-real-base64-or-hex-32-byte-key

# Optional one-time admin bootstrap
BOOTSTRAP_DEFAULT_ADMIN=0
DEFAULT_ADMIN_EMAIL=
DEFAULT_ADMIN_PASSWORD=

# API and services
PORT_API=4000
PORT_WEB=5173
PORT_AI=8000
AI_SERVICE_URL=http://localhost:8000
AI_API_KEY=local-dev-key
AUTO_START_LOCAL_AI_SERVICE=1

# Optional LLM providers
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:3b
OLLAMA_TIMEOUT_MS=60000
OLLAMA_FALLBACK_MODEL=qwen2.5:3b
OLLAMA_FALLBACK_TIMEOUT_MS=20000
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
OPENAI_REASONING_EFFORT=low

# Frontend
VITE_API_URL=http://localhost:4000
VITE_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# Mail / OTP
APP_TIMEZONE=Asia/Ho_Chi_Minh
EMAIL_OTP_MODE=smtp
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="FPIPay <noreply@example.com>"

# SMS / Twilio
SMS_OTP_MODE=console
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# OTP policy
OTP_RESEND_COOLDOWN_SECONDS=60
OTP_MAX_ATTEMPTS=5
LOGIN_OTP_TTL_MINUTES=5
HIGH_RISK_LOGIN_OTP_MAX_ATTEMPTS=3
TRANSFER_OTP_TTL_MINUTES=5
TRANSFER_OTP_MAX_ATTEMPTS=5
RESET_PASSWORD_OTP_TTL_MINUTES=10

# Transfer / risk controls
TRANSFER_HIGH_RISK_IMMEDIATE_BLOCK=0
TRANSFER_MEDIUM_RISK_OTP_MIN_AMOUNT=250
TRANSFER_FACE_ID_THRESHOLD=1000
MEDIUM_RISK_TRANSFER_LIMIT=500
TRANSFER_SCAM_BLOCK_MIN_AMOUNT=100000
TRANSFER_SCAM_BLOCK_MAX_REMAINING_BALANCE=0.01
TRANSFER_SCAM_BLOCK_SPEND_SURGE_RATIO=6
TRANSFER_SCAM_HOLD_SECONDS=20
TRANSFER_SCAM_HOLD_MINUTES=30
KNOWN_RECIPIENT_LOOKBACK_DAYS=180
HIGH_RISK_LOGIN_BLOCK_MINUTES=10
AI_STRICT_MODEL_ONLY=1

# Mongo (optional)
MONGODB_URI=
MONGODB_DB=ComputerResearchProject
